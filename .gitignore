# ---- Data (exclude large files) ----
data/raw/
data/interim/
data/processed/
*.sqlite

# Keep small CSVs if needed for examples
# data/**/*.csv

# ---- Results (SELECTIVE) ----
# Exclude large files (plots, zips, large CSVs)
results/**/plots/
results/**/run_bundle.zip
results/**/*.png
results/**/*.jpg
results/**/*.pdf

# Exclude likelihood curves (can be large)
results/**/ll_*.png

# INCLUDE results JSONs (small, important)
!results/**/*.json
!results/**/*.txt

# Keep .gitkeep
!results/.gitkeep